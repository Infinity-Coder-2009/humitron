{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Humitron",
  "version": "0.2.0",
  "identifier": "dev.humitron.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Humitron",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sidecars/*"
    ],
    "externalBin": [],
    "copyright": "© 2024 Humitron Contributors",
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI Agent",
    "longDescription": "Humitron is a local-first AI agent that runs on your terms. Uses Ollama for local inference, with optional cloud bursting.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "sidecar": true
    },
    "fs": {
      "scope": {
        "allowed": ["$APPCONFIG/*", "$APPDATA/*", "$HOME/*"]
      }
    }
  }
}
# Humitron Environment Variables
# Copy to .env and customize

# Core
HUMITRON_MODEL=llama3.2
HUMITRON_WORKSPACE=.
HUMITRON_MAX_STEPS=20
HUMITRON_TEMPERATURE=0.7
HUMITRON_OLLAMA_URL=http://localhost:11434
HUMITRON_LOG_LEVEL=INFO

# Cloud Provider (choose one)
# HUMITRON_PROVIDER=ollama
# HUMITRON_PROVIDER=openai
# HUMITRON_PROVIDER=anthropic
# HUMITRON_PROVIDER=openrouter

# API Keys (only needed for cloud providers)
# HUMITRON_CLOUD_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# MCP (optional)
# HUMITRON_ENABLE_MCP=false

# Safety
# HUMITRON_SANDBOX=false
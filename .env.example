# Humitron Environment Variables
# Copy this file to .env and customize

# Model Configuration
HUMITRON_MODEL=llama3.2
HUMITRON_WORKSPACE=.
HUMITRON_MAX_STEPS=20
HUMITRON_TEMPERATURE=0.7

# Ollama Configuration
HUMITRON_OLLAMA_URL=http://localhost:11434

# Token Limits
HUMITRON_MAX_TOKENS_SESSION=100000
HUMITRON_MAX_TOKENS_CALL=8000

# Logging
HUMITRON_LOG_LEVEL=INFO

# Features
HUMITRON_ENABLE_MCP=false
HUMITRON_TRAJECTORY_LOGGING=true

# Health & Metrics
HUMITRON_HEALTH_PORT=8080
HUMITRON_PROMETHEUS=false
HUMITRON_PROMETHEUS_PORT=9090

# Rate Limiting
HUMITRON_RATE_LIMIT_RPM=60
HUMITRON_RATE_LIMIT_TPD=1000000

# Sandbox Mode
HUMITRON_SANDBOX=false